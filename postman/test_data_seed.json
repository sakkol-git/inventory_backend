    "edge_cases": [
      {
        "name": "Empty String",
        "test": "Set name field to empty string",
        "payload": {
          "name": "",
          "email": "test@example.com"
        },
        "expected": "Validation error"
      },
      {
        "name": "Maximum Length",
        "test": "Set name to 256+ characters",
        "payload": {
          "name": "a" * 256
        },
        "expected": "Validation error - exceeds max length"
      },
      {
        "name": "Null Values",
        "test": "Send null instead of string",
        "payload": {
          "name": null
        },
        "expected": "Type error or validation error"
      },
      {
        "name": "Special Characters",
        "test": "Unicode and special characters in text fields",
        "payload": {
          "name": "นั้น 中文 العربية emoji🎉"
        },
        "expected": "Should accept and store correctly"
      },
      {
        "name": "Future Date",
        "test": "Set borrow due_at to far future",
        "payload": {
          "due_at": "2099-12-31"
        },
        "expected": "Should accept"
      },
      {
        "name": "Past Date",
        "test": "Set borrow due_at to past",
        "payload": {
          "due_at": "2020-01-01"
        },
        "expected": "Validation error - must be future date"
      },
      {
        "name": "Negative Numbers",
        "test": "Set quantity to negative",
        "payload": {
          "quantity": -100
        },
        "expected": "Validation error - must be positive"
      },
      {
        "name": "Large Numbers",
