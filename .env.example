APP_NAME="Inventory API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── App Locale ───────────────────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Application Maintenance ──────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file

# ── Security ─────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravelinventory
DB_USERNAME=root
DB_PASSWORD=

# ── Image Storage ───────────────────────────────────────────────────
# Set to "s3" for Cloudflare R2 / AWS S3, "local" for local storage
IMAGE_STORAGE_DISK=local
# AWS_BUCKET=
# AWS_DEFAULT_REGION=auto
# AWS_ENDPOINT=
# AWS_URL=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Session ──────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting ────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Filesystem ───────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Queue ────────────────────────────────────────────────────────────
# Use "redis" in production for better performance
QUEUE_CONNECTION=database

# ── Cache ────────────────────────────────────────────────────────────
# Use "redis" in production for better performance
CACHE_STORE=database

# ── Redis (Recommended for production cache & queue) ─────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Frontend origin used by config/cors.php ──────────────────────────
FRONTEND_URL=http://localhost:8081

# ── JWT Authentication (php-open-source-saver/jwt-auth) ──────────────
# IMPORTANT: Generate with `php artisan jwt:secret` — NEVER commit the value
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ── Activity Log ─────────────────────────────────────────────────────
ACTIVITY_LOG_ENABLED=true

# ── Slow Query Logging ───────────────────────────────────────────────
DB_SLOW_QUERY_MS=500
